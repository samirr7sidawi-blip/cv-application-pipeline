# Copy this file to /etc/cv_agent.env on the droplet and fill in the values.
# systemd loads it via the EnvironmentFile directive in cv_agent.service.
#
# Permissions: chmod 640 /etc/cv_agent.env && chown root:cvagent /etc/cv_agent.env

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- FlowCV (used by read_cv_flowcv.py --refresh) ---
FLOWCV_EMAIL=
FLOWCV_PASSWORD=

# --- Gmail (SMTP send via send_email.py) ---
GMAIL_EMAIL=you@example.com
GMAIL_APP_PASSWORD=

# --- Google Sheets (log_to_sheets.py) ---
# Path to the service-account JSON on the droplet, e.g. /opt/cv_agent/credentials.json
GOOGLE_CREDENTIALS_FILE=/opt/cv_agent/credentials.json
# Leave blank on first run — log_to_sheets.py will create the sheet and write the ID back here
GOOGLE_SHEETS_ID=

# --- Webhook server ---
# Generate with: openssl rand -hex 32
# Use the SAME value in the iOS Shortcut's Authorization header.
WEBHOOK_TOKEN=

# Where webhook + pipeline logs are written
CV_AGENT_LOG_DIR=/var/log/cv_agent
